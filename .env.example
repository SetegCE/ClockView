# Variáveis de ambiente necessárias para o ClockView
# Copie este arquivo para .env.local e preencha com os valores reais

# ─── Clockify API ─────────────────────────────────────────────────────────────
CLOCKIFY_API_TOKEN=
CLOCKIFY_WORKSPACE_ID=

# ─── Códigos de acesso (login) ────────────────────────────────────────────────
# Defina um código único para cada usuário autorizado
ACCESS_CODE_1=
ACCESS_CODE_2=
