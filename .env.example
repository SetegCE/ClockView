# Variáveis de ambiente necessárias para o ClockView
# Copie este arquivo para .env.local e preencha com os valores reais
#
#   cp .env.example .env.local
#
# ATENÇÃO: Nunca comite o arquivo .env.local no repositório.

# ─────────────────────────────────────────────────────────────────────────────
# Clockify API
# ─────────────────────────────────────────────────────────────────────────────

# Token de autenticação da Clockify API
# Como obter: acesse https://app.clockify.me/user/settings, seção "API",
#             clique em "Generate" para criar um novo token pessoal.
CLOCKIFY_API_TOKEN=

# ID do workspace Clockify a ser consultado
# Como obter: acesse o workspace no Clockify e copie o ID da URL:
#             https://app.clockify.me/tracker/{WORKSPACE_ID}
#             Ou via API: GET https://api.clockify.me/api/v1/workspaces
CLOCKIFY_WORKSPACE_ID=
